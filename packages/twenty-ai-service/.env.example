# twenty-ai-service environment configuration
# Copy to .env and fill in real values.

# ── HuggingFace / Model Cache ──────────────────────────────────────────
HF_HOME=/app/.cache/huggingface
PORT=8001

# ── LLM Provider (OpenAI — recommended) ───────────────────────────────
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-openai-api-key
OPENAI_API_KEY=your-openai-api-key

# Registered aliases: gpt-4o, gpt-4o-mini, deepseek-v4-flash, qwen3-next-80b
LLM_MODEL=gpt-4o-mini
ORCHESTRATOR_MODEL=gpt-4o
FOLLOWUP_ORCHESTRATOR_MODEL=gpt-4o

# For OpenRouter instead:
# LLM_PROVIDER=openrouter
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=your-openrouter-key
# LLM_MODEL=qwen/qwen3-next-80b-a3b-instruct
# ORCHESTRATOR_MODEL=deepseek/deepseek-v4-flash

# ── Twenty CRM Identity ───────────────────────────────────────────────
TWENTY_WORKSPACE_ID=your-workspace-id
TWENTY_USER_ID=your-user-id

# ── Agent Role IDs (dual-role enforcement) ─────────────────────────────
TWENTY_ROLE_ID=your-fallback-role-id
TWENTY_READER_ROLE_ID=your-reader-role-id
TWENTY_WRITER_ROLE_ID=your-writer-role-id

# ── Node Bridge ───────────────────────────────────────────────────────
NODE_BRIDGE_BASE_URL=http://localhost:3000/agent-bridge
AI_AGENT_USE_EXTERNAL_ORCHESTRATOR=true
AI_SERVICE_URL=http://127.0.0.1:8001

# ── Database (follow-up agent schema) ─────────────────────────────────
PG_DATABASE_URL=postgres://postgres:postgres@localhost:5432/default

# ── LangSmith tracing ─────────────────────────────────────────────────
LANGSMITH_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=twenty-ai-service
LANGCHAIN_TRACING_V2=true
