# twenty-ai-service environment configuration
# Copy to .env and fill in real values.

# ── HuggingFace / Model Cache ──────────────────────────────────────────
HF_HOME=/app/.cache/huggingface
PORT=8001

# ── LLM Provider (OpenRouter) ─────────────────────────────────────────
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-key-here
# A registered alias (see agent/models.py: deepseek-v4-flash, deepseek-v4-pro,
# qwen3-next-80b, gpt-4o, gpt-4o-mini) OR any full OpenRouter slug.
# Override per-worker/per-call with LLMClient(model=...) / worker.run(model=...).
#
# LLM_MODEL is the default for the sub-agents (reader + writer).
# ORCHESTRATOR_MODEL is the orchestrator's own planning/routing loop.
LLM_MODEL=qwen/qwen3-next-80b-a3b-instruct
ORCHESTRATOR_MODEL=deepseek/deepseek-v4-flash

# ── Twenty CRM Identity ───────────────────────────────────────────────
# Shared across all agent scopes.
TWENTY_WORKSPACE_ID=your-workspace-id
TWENTY_USER_ID=your-user-id

# ── Agent Role IDs (dual-role enforcement) ─────────────────────────────
# Create two least-privilege roles in Twenty's Settings → Roles:
#
# 1. "agent-reader" — READ-ONLY object permissions (canReadPerson, etc.)
#    Assign its UUID to TWENTY_READER_ROLE_ID.
#
# 2. "agent-writer" — READ + CREATE + UPDATE (no delete unless required)
#    Assign its UUID to TWENTY_WRITER_ROLE_ID.
#
# If you only have one role during dev, set TWENTY_ROLE_ID as a fallback.
TWENTY_ROLE_ID=your-fallback-role-id
TWENTY_READER_ROLE_ID=your-reader-role-id
TWENTY_WRITER_ROLE_ID=your-writer-role-id

# ── Node Bridge ───────────────────────────────────────────────────────
NODE_BRIDGE_BASE_URL=http://localhost:3000/agent-bridge
