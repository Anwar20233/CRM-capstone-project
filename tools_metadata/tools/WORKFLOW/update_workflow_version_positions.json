{
  "name": "update_workflow_version_positions",
  "description": "Update the positions of multiple workflow steps. This is useful for reorganizing the workflow layout.",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "workflowVersionId": {
        "description": "The UUID of the workflow version",
        "type": "string",
        "format": "uuid",
        "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
      },
      "positions": {
        "description": "Array of step positions to update",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "description": "Step or trigger ID",
              "type": "string"
            },
            "position": {
              "type": "object",
              "properties": {
                "x": {
                  "type": "number"
                },
                "y": {
                  "type": "number"
                }
              },
              "required": [
                "x",
                "y"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "id",
            "position"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "workflowVersionId",
      "positions"
    ],
    "additionalProperties": false
  }
}