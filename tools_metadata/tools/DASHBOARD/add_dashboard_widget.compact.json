{
  "name": "add_dashboard_widget",
  "description": "Add a widget to an existing dashboard tab.\n\nUse get_dashboard first to get pageLayoutTabId and existing widget positions.\nUse list_object_metadata_items to get objectMetadataId and field IDs for GRAPH widgets.\n\nFor RECORD_TABLE widgets: create a dedicated view first with create_view (type TABLE), then pass its viewId in configuration. Never reuse an existing record index view.\n\nSee create_complete_dashboard for full configuration examples.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "pageLayoutTabId": {
        "description": "Tab UUID from get_dashboard",
        "type": "string",
        "format": "uuid"
      },
      "title": {
        "description": "Widget title",
        "type": "string"
      },
      "type": {
        "description": "Widget type",
        "type": "string",
        "enum": [
          "VIEW",
          "GRAPH",
          "IFRAME",
          "STANDALONE_RICH_TEXT",
          "RECORD_TABLE"
        ]
      },
      "gridPosition": {
        "description": "Position in 12-column grid",
        "type": "object",
        "properties": {
          "row": {
            "description": "Row position (0-based)",
            "type": "number",
            "minimum": 0
          },
          "column": {
            "description": "Column position (0-11 for 12-column grid)",
            "type": "number",
            "minimum": 0,
            "maximum": 11
          },
          "rowSpan": {
            "description": "Number of rows the widget spans",
            "type": "number",
            "minimum": 1
          },
          "columnSpan": {
            "description": "Number of columns the widget spans (1-12)",
            "type": "number",
            "minimum": 1,
            "maximum": 12
          }
        },
        "required": [
          "row",
          "column",
          "rowSpan",
          "columnSpan"
        ]
      },
      "objectMetadataId": {
        "description": "Required for GRAPH and RECORD_TABLE widgets: object UUID to aggregate or display",
        "type": "string",
        "format": "uuid"
      },
      "configuration": {
        "description": "Widget configuration - structure depends on widget type",
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "configurationType": {
                "type": "string",
                "const": "AGGREGATE_CHART"
              },
              "aggregateFieldMetadataId": {
                "description": "Field UUID to aggregate (must be from the widget objectMetadataId)",
                "type": "string",
                "format": "uuid"
              },
              "aggregateOperation": {
                "description": "Aggregation operation: COUNT, SUM, AVG, MIN, MAX, etc.",
                "type": "string",
                "enum": [
                  "MIN",
                  "MAX",
                  "AVG",
                  "SUM",
                  "COUNT",
                  "COUNT_UNIQUE_VALUES",
                  "COUNT_EMPTY",
                  "COUNT_NOT_EMPTY",
                  "COUNT_TRUE",
                  "COUNT_FALSE",
                  "PERCENTAGE_EMPTY",
                  "PERCENTAGE_NOT_EMPTY"
                ]
              },
              "label": {
                "type": "string"
              },
              "displayDataLabel": {
                "default": true,
                "type": "boolean"
              },
              "prefix": {
                "type": "string"
              },
              "suffix": {
                "type": "string"
              },
              "ratioAggregateConfig": {
                "type": "object",
                "properties": {
                  "fieldMetadataId": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "optionValue": {
                    "type": "string"
                  }
                },
                "required": [
                  "fieldMetadataId",
                  "optionValue"
                ]
              }
            },
            "required": [
              "configurationType",
              "aggregateFieldMetadataId",
              "aggregateOperation",
              "displayDataLabel"
            ]
          },
          {
            "type": "object",
            "properties": {
              "configurationType": {
                "type": "string",
                "const": "BAR_CHART"
              },
              "aggregateFieldMetadataId": {
                "description": "Field UUID to aggregate",
                "type": "string",
                "format": "uuid"
              },
              "aggregateOperation": {
                "type": "string",
                "enum": [
                  "MIN",
                  "MAX",
                  "AVG",
                  "SUM",
                  "COUNT",
                  "COUNT_UNIQUE_VALUES",
                  "COUNT_EMPTY",
                  "COUNT_NOT_EMPTY",
                  "COUNT_TRUE",
                  "COUNT_FALSE",
                  "PERCENTAGE_EMPTY",
                  "PERCENTAGE_NOT_EMPTY"
                ]
              },
              "primaryAxisGroupByFieldMetadataId": {
                "description": "Field UUID to group by on primary axis",
                "type": "string",
                "format": "uuid"
              },
              "primaryAxisGroupBySubFieldName": {
                "description": "REQUIRED for relation fields (e.g. \"name\", \"address.addressCity\") and composite fields (e.g. \"addressCity\"). Without this, relation fields group by raw UUID which is not useful.",
                "type": "string"
              },
              "secondaryAxisGroupByFieldMetadataId": {
                "type": "string",
                "format": "uuid"
              },
              "secondaryAxisGroupBySubFieldName": {
                "description": "REQUIRED for relation fields (e.g. \"name\", \"stage\") and composite fields (e.g. \"addressCity\"). Without this, relation fields group by raw UUID which is not useful.",
                "type": "string"
              },
              "primaryAxisOrderBy": {
                "type": "string",
                "enum": [
                  "FIELD_ASC",
                  "FIELD_DESC",
                  "FIELD_POSITION_ASC",
                  "FIELD_POSITION_DESC",
                  "VALUE_ASC",
                  "VALUE_DESC",
                  "MANUAL"
                ]
              },
              "primaryAxisManualSortOrder": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "secondaryAxisOrderBy": {
                "type": "string",
                "enum": [
                  "FIELD_ASC",
                  "FIELD_DESC",
                  "FIELD_POSITION_ASC",
                  "FIELD_POSITION_DESC",
                  "VALUE_ASC",
                  "VALUE_DESC",
                  "MANUAL"
                ]
              },
              "secondaryAxisManualSortOrder": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "omitNullValues": {
                "type": "boolean"
              },
              "primaryAxisDateGranularity": {
                "description": "Date grouping granularity for X axis",
                "type": "string",
                "enum": [
                  "DAY",
                  "WEEK",
                  "MONTH",
                  "QUARTER",
                  "YEAR",
                  "DAY_OF_THE_WEEK",
                  "MONTH_OF_THE_YEAR",
                  "QUARTER_OF_THE_YEAR"
                ]
              },
              "secondaryAxisGroupByDateGranularity": {
                "description": "Date grouping granularity for secondary grouping",
                "type": "string",
                "enum": [
                  "DAY",
                  "WEEK",
                  "MONTH",
                  "QUARTER",
                  "YEAR",
                  "DAY_OF_THE_WEEK",
                  "MONTH_OF_THE_YEAR",
                  "QUARTER_OF_THE_YEAR"
                ]
              },
              "color": {
                "description": "Chart color theme",
                "$ref": "#/$defs/_f5"
              },
              "axisNameDisplay": {
                "description": "Which axis labels to show",
                "type": "string",
                "enum": [
                  "NONE",
                  "X",
                  "Y",
                  "BOTH"
                ]
              },
              "displayDataLabel": {
                "default": false,
                "type": "boolean"
              },
              "displayLegend": {
                "default": true,
                "type": "boolean"
              },
              "groupMode": {
                "description": "Bar display mode when using secondary grouping",
                "type": "string",
                "enum": [
                  "STACKED",
                  "GROUPED"
                ]
              },
              "isCumulative": {
                "description": "Show running totals",
                "type": "boolean"
              },
              "rangeMin": {
                "description": "Y axis minimum value",
                "type": "number"
              },
              "rangeMax": {
                "description": "Y axis maximum value",
                "type": "number"
              },
              "layout": {
                "description": "Layout orientation for bar charts",
                "type": "string",
                "enum": [
                  "VERTICAL",
                  "HORIZONTAL"
                ]
              }
            },
            "required": [
              "configurationType",
              "aggregateFieldMetadataId",
              "aggregateOperation",
              "primaryAxisGroupByFieldMetadataId",
              "displayDataLabel",
              "displayLegend",
              "layout"
            ]
          },
          {
            "type": "object",
            "properties": {
              "configurationType": {
                "type": "string",
                "const": "LINE_CHART"
              },
              "aggregateFieldMetadataId": {
                "type": "string",
                "format": "uuid"
              },
              "aggregateOperation": {
                "type": "string",
                "enum": [
                  "MIN",
                  "MAX",
                  "AVG",
                  "SUM",
                  "COUNT",
                  "COUNT_UNIQUE_VALUES",
                  "COUNT_EMPTY",
                  "COUNT_NOT_EMPTY",
                  "COUNT_TRUE",
                  "COUNT_FALSE",
                  "PERCENTAGE_EMPTY",
                  "PERCENTAGE_NOT_EMPTY"
                ]
              },
              "primaryAxisGroupByFieldMetadataId": {
                "type": "string",
                "format": "uuid"
              },
              "primaryAxisGroupBySubFieldName": {
                "description": "REQUIRED for relation fields (e.g. \"name\", \"address.addressCity\") and composite fields (e.g. \"addressCity\"). Without this, relation fields group by raw UUID which is not useful.",
                "type": "string"
              },
              "secondaryAxisGroupByFieldMetadataId": {
                "type": "string",
                "format": "uuid"
              },
              "secondaryAxisGroupBySubFieldName": {
                "description": "REQUIRED for relation fields (e.g. \"name\", \"stage\") and composite fields (e.g. \"addressCity\"). Without this, relation fields group by raw UUID which is not useful.",
                "type": "string"
              },
              "primaryAxisOrderBy": {
                "type": "string",
                "enum": [
                  "FIELD_ASC",
                  "FIELD_DESC",
                  "FIELD_POSITION_ASC",
                  "FIELD_POSITION_DESC",
                  "VALUE_ASC",
                  "VALUE_DESC",
                  "MANUAL"
                ]
              },
              "primaryAxisManualSortOrder": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "secondaryAxisOrderBy": {
                "type": "string",
                "enum": [
                  "FIELD_ASC",
                  "FIELD_DESC",
                  "FIELD_POSITION_ASC",
                  "FIELD_POSITION_DESC",
                  "VALUE_ASC",
                  "VALUE_DESC",
                  "MANUAL"
                ]
              },
              "secondaryAxisManualSortOrder": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "omitNullValues": {
                "type": "boolean"
              },
              "primaryAxisDateGranularity": {
                "description": "Date grouping granularity for X axis",
                "type": "string",
                "enum": [
                  "DAY",
                  "WEEK",
                  "MONTH",
                  "QUARTER",
                  "YEAR",
                  "DAY_OF_THE_WEEK",
                  "MONTH_OF_THE_YEAR",
                  "QUARTER_OF_THE_YEAR"
                ]
              },
              "secondaryAxisGroupByDateGranularity": {
                "description": "Date grouping granularity for secondary grouping",
                "type": "string",
                "enum": [
                  "DAY",
                  "WEEK",
                  "MONTH",
                  "QUARTER",
                  "YEAR",
                  "DAY_OF_THE_WEEK",
                  "MONTH_OF_THE_YEAR",
                  "QUARTER_OF_THE_YEAR"
                ]
              },
              "color": {
                "description": "Line color theme",
                "$ref": "#/$defs/_f5"
              },
              "axisNameDisplay": {
                "description": "Which axis labels to show",
                "type": "string",
                "enum": [
                  "NONE",
                  "X",
                  "Y",
                  "BOTH"
                ]
              },
              "displayDataLabel": {
                "default": false,
                "type": "boolean"
              },
              "displayLegend": {
                "default": true,
                "type": "boolean"
              },
              "isStacked": {
                "description": "Stack multiple lines",
                "type": "boolean"
              },
              "isCumulative": {
                "description": "Show running totals",
                "type": "boolean"
              },
              "rangeMin": {
                "description": "Y axis minimum value",
                "type": "number"
              },
              "rangeMax": {
                "description": "Y axis maximum value",
                "type": "number"
              }
            },
            "required": [
              "configurationType",
              "aggregateFieldMetadataId",
              "aggregateOperation",
              "primaryAxisGroupByFieldMetadataId",
              "displayDataLabel",
              "displayLegend"
            ]
          },
          {
            "type": "object",
            "properties": {
              "configurationType": {
                "type": "string",
                "const": "PIE_CHART"
              },
              "aggregateFieldMetadataId": {
                "type": "string",
                "format": "uuid"
              },
              "aggregateOperation": {
                "type": "string",
                "enum": [
                  "MIN",
                  "MAX",
                  "AVG",
                  "SUM",
                  "COUNT",
                  "COUNT_UNIQUE_VALUES",
                  "COUNT_EMPTY",
                  "COUNT_NOT_EMPTY",
                  "COUNT_TRUE",
                  "COUNT_FALSE",
                  "PERCENTAGE_EMPTY",
                  "PERCENTAGE_NOT_EMPTY"
                ]
              },
              "groupByFieldMetadataId": {
                "description": "Field UUID to slice by",
                "type": "string",
                "format": "uuid"
              },
              "groupBySubFieldName": {
                "description": "REQUIRED for relation fields (e.g. \"name\", \"stage\") and composite fields (e.g. \"addressCity\"). Without this, relation fields group by raw UUID which is not useful.",
                "type": "string"
              },
              "orderBy": {
                "type": "string",
                "enum": [
                  "FIELD_ASC",
                  "FIELD_DESC",
                  "FIELD_POSITION_ASC",
                  "FIELD_POSITION_DESC",
                  "VALUE_ASC",
                  "VALUE_DESC",
                  "MANUAL"
                ]
              },
              "manualSortOrder": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "dateGranularity": {
                "description": "Date grouping granularity when slicing by date",
                "type": "string",
                "enum": [
                  "DAY",
                  "WEEK",
                  "MONTH",
                  "QUARTER",
                  "YEAR",
                  "DAY_OF_THE_WEEK",
                  "MONTH_OF_THE_YEAR",
                  "QUARTER_OF_THE_YEAR"
                ]
              },
              "color": {
                "description": "Chart color theme",
                "$ref": "#/$defs/_f5"
              },
              "displayDataLabel": {
                "default": true,
                "type": "boolean"
              },
              "displayLegend": {
                "default": true,
                "type": "boolean"
              },
              "showCenterMetric": {
                "default": true,
                "description": "Show aggregate value in center",
                "type": "boolean"
              },
              "hideEmptyCategory": {
                "default": false,
                "description": "Hide slices with zero values",
                "type": "boolean"
              }
            },
            "required": [
              "configurationType",
              "aggregateFieldMetadataId",
              "aggregateOperation",
              "groupByFieldMetadataId",
              "displayDataLabel",
              "displayLegend",
              "showCenterMetric",
              "hideEmptyCategory"
            ]
          },
          {
            "type": "object",
            "properties": {
              "configurationType": {
                "type": "string",
                "const": "IFRAME"
              },
              "url": {
                "description": "URL to embed",
                "type": "string",
                "format": "uri"
              }
            },
            "required": [
              "configurationType"
            ]
          },
          {
            "type": "object",
            "properties": {
              "configurationType": {
                "type": "string",
                "const": "STANDALONE_RICH_TEXT"
              },
              "body": {
                "description": "Rich text content. Use { \"markdown\": \"your content here\" } for text. Supports full markdown syntax.",
                "type": "object",
                "properties": {
                  "blocknote": {
                    "description": "BlockNote JSON string (advanced). Stringified array of BlockNote blocks.",
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "markdown": {
                    "description": "Markdown content string (preferred for AI). Supports headings, bold, lists, links, etc.",
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "null"
                      }
                    ]
                  }
                }
              }
            },
            "required": [
              "configurationType",
              "body"
            ]
          },
          {
            "type": "object",
            "properties": {
              "configurationType": {
                "type": "string",
                "const": "RECORD_TABLE"
              },
              "viewId": {
                "description": "UUID of the dedicated view created for this widget. Must be created with create_view before creating the widget. Never reuse a record index view.",
                "type": "string",
                "format": "uuid"
              }
            },
            "required": [
              "configurationType",
              "viewId"
            ]
          }
        ]
      }
    },
    "required": [
      "pageLayoutTabId",
      "title",
      "type",
      "gridPosition"
    ],
    "$defs": {
      "_f5": {
        "type": "string",
        "enum": [
          "auto",
          "red",
          "ruby",
          "crimson",
          "tomato",
          "orange",
          "amber",
          "yellow",
          "lime",
          "grass",
          "green",
          "jade",
          "mint",
          "turquoise",
          "cyan",
          "sky",
          "blue",
          "iris",
          "violet",
          "purple",
          "plum",
          "pink",
          "bronze",
          "gold",
          "brown",
          "gray"
        ]
      }
    }
  }
}