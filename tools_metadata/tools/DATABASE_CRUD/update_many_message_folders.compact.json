                  "NULL",
                  "NOT_NULL"
                ]
              }
            }
          },
          "isSynced": {
            "type": "object",
            "properties": {
              "eq": {
                "type": "boolean"
              },
              "is": {
                "type": "string",
                "enum": [
                  "NULL",
                  "NOT_NULL"
                ]
              }
            }
          },
          "parentFolderId": {
            "$ref": "#/$defs/_f3"
