                      "type": "string"
                    }
                  },
                  "required": [
                    "granularity",
                    "timeZone"
                  ],
                  "additionalProperties": false
                }
              },
              "required": [
                "updatedAt"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "headerMessageId": {
                  "type": "boolean",
                  "const": true
                }
              },
              "required": [
                "headerMessageId"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "subject": {
                  "type": "boolean",
                  "const": true
                }
