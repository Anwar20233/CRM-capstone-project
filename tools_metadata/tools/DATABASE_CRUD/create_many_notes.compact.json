{
  "name": "create_many_notes",
  "description": "Create multiple Notes records in a single call. Provide an array of records, each containing the required fields. Maximum 20 records per call. Returns the created records.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "records": {
        "description": "Array of records to create. Each record should contain the required fields. Maximum 20 records per call.",
        "minItems": 1,
        "maxItems": 20,
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "position": {
              "description": "Use \"first\" to insert at the top, \"last\" for the bottom, or a number for explicit ordering. Leave empty to place at the top (recommended).",
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "string",
                  "const": "first"
                },
                {
                  "type": "string",
                  "const": "last"
                }
              ]
            },
            "title": {
              "description": "Note title",
              "type": "string"
            },
            "bodyV2": {
              "description": "Note body",
              "type": "object",
              "properties": {
                "markdown": {
                  "type": "string"
                },
                "blocknote": {
                  "type": "string"
                }
              }
            }
          },
          "required": [
            "position"
          ]
        }
      }
    },
    "required": [
      "records"
    ]
  }
}