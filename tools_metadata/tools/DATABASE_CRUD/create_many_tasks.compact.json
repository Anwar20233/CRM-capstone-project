{
  "name": "create_many_tasks",
  "description": "Create multiple Tasks records in a single call. Provide an array of records, each containing the required fields. Maximum 20 records per call. Returns the created records.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "records": {
        "description": "Array of records to create. Each record should contain the required fields. Maximum 20 records per call.",
        "minItems": 1,
        "maxItems": 20,
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "position": {
              "description": "Use \"first\" to insert at the top, \"last\" for the bottom, or a number for explicit ordering. Leave empty to place at the top (recommended).",
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "string",
                  "const": "first"
                },
                {
                  "type": "string",
                  "const": "last"
                }
              ]
            },
            "title": {
              "description": "Task title",
              "type": "string"
            },
            "bodyV2": {
              "description": "Task body",
              "type": "object",
              "properties": {
                "markdown": {
                  "type": "string"
                },
                "blocknote": {
                  "type": "string"
                }
              }
            },
            "dueAt": {
              "description": "Task due date",
              "type": "string",
              "format": "date-time"
            },
            "status": {
              "description": "Task status",
              "type": "string",
              "enum": [
                "TODO",
                "IN_PROGRESS",
                "DONE"
              ]
            },
            "assigneeId": {
              "type": "string",
              "format": "uuid"
            }
          },
          "required": [
            "position"
          ]
        }
      }
    },
    "required": [
      "records"
    ]
  }
}