{
  "name": "create_many_timeline_activities",
  "description": "Create multiple Timeline Activities records in a single call. Provide an array of records, each containing the required fields. Maximum 20 records per call. Returns the created records.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "records": {
        "description": "Array of records to create. Each record should contain the required fields. Maximum 20 records per call.",
        "minItems": 1,
        "maxItems": 20,
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "position": {
              "description": "Use \"first\" to insert at the top, \"last\" for the bottom, or a number for explicit ordering. Leave empty to place at the top (recommended).",
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "string",
                  "const": "first"
                },
                {
                  "type": "string",
                  "const": "last"
                }
              ]
            },
            "happensAt": {
              "description": "Creation date",
              "type": "string",
              "format": "date-time"
            },
            "name": {
              "description": "Event name",
              "type": "string"
            },
            "properties": {
              "description": "Json value for event details",
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {}
            },
            "linkedRecordCachedName": {
              "description": "Cached record name",
              "type": "string"
            },
            "linkedRecordId": {
              "description": "Linked Record id",
              "type": "string",
              "format": "uuid"
            },
            "linkedObjectMetadataId": {
              "description": "Linked Object Metadata Id",
              "type": "string",
              "format": "uuid"
            },
            "targetCompany": {
              "description": "Event target",
              "type": "string"
            },
            "targetDashboard": {
              "description": "Event target",
              "type": "string"
            },
            "targetNote": {
              "description": "Event target",
              "type": "string"
            },
            "targetOpportunity": {
              "description": "Event target",
              "type": "string"
            },
            "targetPerson": {
              "description": "Event target",
              "type": "string"
            },
            "targetTask": {
              "description": "Event target",
              "type": "string"
            },
            "workspaceMemberId": {
              "type": "string",
              "format": "uuid"
            },
            "targetWorkflow": {
              "description": "Event target",
              "type": "string"
            },
            "targetWorkflowVersion": {
              "description": "Event target",
              "type": "string"
            },
            "targetWorkflowRun": {
              "description": "Event target",
              "type": "string"
            }
          },
          "required": [
            "position",
            "happensAt"
          ]
        }
      }
    },
    "required": [
      "records"
    ]
  }
}