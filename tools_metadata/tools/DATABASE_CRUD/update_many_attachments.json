            "type": "string"
          },
          "targetDashboard": {
            "description": "Attachment target",
            "type": "string"
          },
          "targetWorkflow": {
            "description": "Attachment target",
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "required": [
      "filter",
      "data"
    ],
    "additionalProperties": false,
