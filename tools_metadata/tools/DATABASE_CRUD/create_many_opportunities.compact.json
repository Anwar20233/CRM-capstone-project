{
  "name": "create_many_opportunities",
  "description": "Create multiple Opportunities records in a single call. Provide an array of records, each containing the required fields. Maximum 20 records per call. Returns the created records.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "records": {
        "description": "Array of records to create. Each record should contain the required fields. Maximum 20 records per call.",
        "minItems": 1,
        "maxItems": 20,
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "description": "The opportunity name",
              "type": "string"
            },
            "amount": {
              "description": "Opportunity amount",
              "type": "object",
              "properties": {
                "amountMicros": {
                  "type": "number"
                },
                "currencyCode": {
                  "type": "string"
                }
              }
            },
            "closeDate": {
              "description": "Opportunity close date",
              "type": "string",
              "format": "date-time"
            },
            "stage": {
              "description": "Opportunity stage",
              "type": "string",
              "enum": [
                "NEW",
                "SCREENING",
                "MEETING",
                "PROPOSAL",
                "CUSTOMER"
              ]
            },
            "position": {
              "description": "Use \"first\" to insert at the top, \"last\" for the bottom, or a number for explicit ordering. Leave empty to place at the top (recommended).",
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "string",
                  "const": "first"
                },
                {
                  "type": "string",
                  "const": "last"
                }
              ]
            },
            "companyId": {
              "type": "string",
              "format": "uuid"
            },
            "pointOfContactId": {
              "type": "string",
              "format": "uuid"
            },
            "ownerId": {
              "type": "string",
              "format": "uuid"
            }
          },
          "required": [
            "stage",
            "position"
          ]
        }
      }
    },
    "required": [
      "records"
    ]
  }
}