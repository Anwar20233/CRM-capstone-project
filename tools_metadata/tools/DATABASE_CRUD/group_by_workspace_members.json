{
  "name": "group_by_workspace_members",
  "description": "Group Workspace Members records by one or two fields and compute an aggregate (COUNT, SUM, AVG, MIN, MAX, etc.). Use for questions like \"how many deals per stage?\" or \"total revenue by company\". Returns groups with dimension values and aggregate results, ordered by the aggregate value.",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "groupBy": {
        "description": "Fields to group by (max 2). Each entry must be an object with exactly one field key. Examples: {\"status\": true}, {\"companyId\": true}, {\"createdAt\": {\"granularity\": \"MONTH\", \"timeZone\": \"UTC\"}}. Available: createdAt (date), updatedAt (date), name.firstName, name.lastName.",
        "minItems": 1,
        "maxItems": 2,
        "type": "array",
        "items": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "createdAt": {
                  "description": "Date field grouping configuration",
                  "type": "object",
                  "properties": {
                    "granularity": {
                      "description": "Date grouping granularity. Default: MONTH.",
                      "default": "MONTH",
                      "type": "string",
                      "enum": [
                        "DAY",
                        "MONTH",
                        "QUARTER",
                        "YEAR",
                        "WEEK",
                        "DAY_OF_THE_WEEK",
                        "MONTH_OF_THE_YEAR",
                        "QUARTER_OF_THE_YEAR"
                      ]
                    },
                    "weekStartDay": {
                      "description": "First day of week (MONDAY, SUNDAY, SATURDAY). Only used when granularity is WEEK.",
                      "type": "string",
                      "enum": [
                        "MONDAY",
                        "SUNDAY",
                        "SATURDAY"
                      ]
                    },
                    "timeZone": {
                      "description": "IANA timezone for date groupings (e.g. \"America/New_York\"). Default: UTC.",
                      "default": "UTC",
                      "type": "string"
                    }
                  },
                  "required": [
                    "granularity",
                    "timeZone"
                  ],
                  "additionalProperties": false
                }
              },
              "required": [
                "createdAt"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "updatedAt": {
                  "description": "Date field grouping configuration",
                  "type": "object",
                  "properties": {
                    "granularity": {
                      "description": "Date grouping granularity. Default: MONTH.",
                      "default": "MONTH",
                      "type": "string",
                      "enum": [
                        "DAY",
                        "MONTH",
                        "QUARTER",
                        "YEAR",
                        "WEEK",
                        "DAY_OF_THE_WEEK",
                        "MONTH_OF_THE_YEAR",
                        "QUARTER_OF_THE_YEAR"
                      ]
                    },
                    "weekStartDay": {
                      "description": "First day of week (MONDAY, SUNDAY, SATURDAY). Only used when granularity is WEEK.",
                      "type": "string",
                      "enum": [
                        "MONDAY",
                        "SUNDAY",
                        "SATURDAY"
                      ]
                    },
                    "timeZone": {
                      "description": "IANA timezone for date groupings (e.g. \"America/New_York\"). Default: UTC.",
                      "default": "UTC",
                      "type": "string"
                    }
                  },
                  "required": [
                    "granularity",
                    "timeZone"
                  ],
                  "additionalProperties": false
                }
              },
              "required": [
                "updatedAt"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "object",
                  "properties": {
                    "firstName": {
                      "type": "boolean",
                      "const": true
                    }
                  },
                  "required": [
                    "firstName"
                  ],
                  "additionalProperties": false
                }
              },
              "required": [
                "name"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "object",
                  "properties": {
                    "lastName": {
                      "type": "boolean",
                      "const": true
                    }
                  },
                  "required": [
                    "lastName"
                  ],
                  "additionalProperties": false
                }
              },
              "required": [
                "name"
              ],
              "additionalProperties": false
            }
          ]
        }
      },
      "aggregateOperation": {
        "description": "Aggregate operation to apply per group. Default: COUNT. Any operation other than COUNT requires aggregateFieldName.",
        "default": "COUNT",
        "type": "string",
        "enum": [
          "MIN",
          "MAX",
          "AVG",
          "SUM",
          "COUNT",
          "COUNT_UNIQUE_VALUES",
          "COUNT_EMPTY",
          "COUNT_NOT_EMPTY",
          "COUNT_TRUE",
          "COUNT_FALSE",
          "PERCENTAGE_EMPTY",
          "PERCENTAGE_NOT_EMPTY"
        ]
      },
      "aggregateFieldName": {
        "description": "Field to aggregate. Required for any operation other than COUNT. Available fields: id, createdAt, updatedAt, deletedAt, position, name, colorScheme, locale, avatarUrl, userEmail, calendarStartDay, userId, timeZone, dateFormat, timeFormat, numberFormat, searchVector, createdBy, updatedBy.",
        "type": "string"
      },
      "limit": {
        "description": "Maximum number of groups to return (default: 50, max: 100).",
        "default": 50,
        "type": "integer",
        "exclusiveMinimum": 0,
        "maximum": 100
      },
      "orderBy": {
        "description": "Order groups by aggregate value. DESC (default) gives \"top N\" behavior.",
        "default": "DESC",
        "type": "string",
        "enum": [
          "ASC",
          "DESC"
        ]
      },
      "name": {
        "description": "Filter by name (full name field)",
        "type": "object",
        "properties": {
          "firstName": {
            "description": "Filter by first name",
            "type": "object",
            "properties": {
              "eq": {
                "description": "First name equals",
                "type": "string"
              },
              "neq": {
                "description": "First name not equals",
                "type": "string"
              },
              "like": {
                "description": "First name case-sensitive pattern match",
                "type": "string"
              },
              "ilike": {
                "description": "First name case-insensitive pattern match",
                "type": "string"
              },
              "startsWith": {
                "description": "First name starts with",
                "type": "string"
              },
              "endsWith": {
                "description": "First name ends with",
                "type": "string"
              },
              "is": {
                "description": "Check for missing or empty first name. Use \"NULL\" to find records with no first name, \"NOT_NULL\" for records with a first name",
                "type": "string",
                "enum": [
                  "NULL",
                  "NOT_NULL"
                ]
              }
            },
            "additionalProperties": false
          },
          "lastName": {
            "description": "Filter by last name",
            "type": "object",
            "properties": {
              "eq": {
                "description": "Last name equals",
                "type": "string"
              },
              "neq": {
                "description": "Last name not equals",
                "type": "string"
              },
              "like": {
                "description": "Last name case-sensitive pattern match",
                "type": "string"
              },
              "ilike": {
                "description": "Last name case-insensitive pattern match",
                "type": "string"
              },
              "startsWith": {
                "description": "Last name starts with",
                "type": "string"
              },
              "endsWith": {
                "description": "Last name ends with",
                "type": "string"
              },
              "is": {
                "description": "Check for missing or empty last name. Use \"NULL\" to find records with no last name, \"NOT_NULL\" for records with a last name",
                "type": "string",
                "enum": [
                  "NULL",
                  "NOT_NULL"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "or": {
        "description": "OR condition - matches if ANY of the filters match",
        "type": "array",
        "items": {
          "$ref": "#/$defs/__schema0"
        }
      },
      "and": {
        "description": "AND condition - matches if ALL filters match",
        "type": "array",
        "items": {
          "$ref": "#/$defs/__schema0"
        }
      },
      "not": {
        "description": "NOT condition - matches if the filter does NOT match",
        "$ref": "#/$defs/__schema0"
      }
    },
    "required": [
      "groupBy",
      "aggregateOperation",
      "limit",
      "orderBy"
    ],
    "additionalProperties": false,
    "$defs": {
