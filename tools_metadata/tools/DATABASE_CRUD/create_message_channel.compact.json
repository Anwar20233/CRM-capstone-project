{
  "name": "create_message_channel",
  "description": "Create a new Message Channel record. Provide all required fields and any optional fields you want to set. The system will automatically handle timestamps and IDs. Returns the created record with all its data.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "position": {
        "description": "Use \"first\" to insert at the top, \"last\" for the bottom, or a number for explicit ordering. Leave empty to place at the top (recommended).",
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "string",
            "const": "first"
          },
          {
            "type": "string",
            "const": "last"
          }
        ]
      },
      "visibility": {
        "description": "Visibility",
        "type": "string",
        "enum": [
          "METADATA",
          "SUBJECT",
          "SHARE_EVERYTHING"
        ]
      },
      "handle": {
        "description": "Handle",
        "type": "string"
      },
      "type": {
        "description": "Channel Type",
        "type": "string",
        "enum": [
          "EMAIL",
          "SMS",
          "EMAIL_GROUP"
        ]
      },
      "isContactAutoCreationEnabled": {
        "description": "Is Contact Auto Creation Enabled",
        "type": "boolean"
      },
      "contactAutoCreationPolicy": {
        "description": "Automatically create People records when receiving or sending emails",
        "type": "string",
        "enum": [
          "SENT_AND_RECEIVED",
          "SENT",
          "NONE"
        ]
      },
      "messageFolderImportPolicy": {
        "description": "Message folder import policy",
        "type": "string",
        "enum": [
          "ALL_FOLDERS",
          "SELECTED_FOLDERS"
        ]
      },
      "excludeNonProfessionalEmails": {
        "description": "Exclude non professional emails",
        "type": "boolean"
      },
      "excludeGroupEmails": {
        "description": "Exclude group emails",
        "type": "boolean"
      },
      "pendingGroupEmailsAction": {
        "description": "Pending action for group emails",
        "type": "string",
        "enum": [
          "GROUP_EMAILS_DELETION",
          "GROUP_EMAILS_IMPORT",
          "NONE"
        ]
      },
      "isSyncEnabled": {
        "description": "Is Sync Enabled",
        "type": "boolean"
      },
      "syncCursor": {
        "description": "Last sync cursor",
        "type": "string"
      },
      "syncedAt": {
        "description": "Last sync date",
        "type": "string",
        "format": "date-time"
      },
      "syncStatus": {
        "description": "Sync status",
        "type": "string",
        "enum": [
          "ONGOING",
          "NOT_SYNCED",
          "ACTIVE",
          "FAILED_INSUFFICIENT_PERMISSIONS",
          "FAILED_UNKNOWN"
        ]
      },
      "syncStage": {
        "description": "Sync stage",
        "type": "string",
        "enum": [
          "MESSAGE_LIST_FETCH_PENDING",
          "MESSAGE_LIST_FETCH_SCHEDULED",
          "MESSAGE_LIST_FETCH_ONGOING",
          "MESSAGES_IMPORT_PENDING",
          "MESSAGES_IMPORT_SCHEDULED",
          "MESSAGES_IMPORT_ONGOING",
          "FAILED",
          "PENDING_CONFIGURATION"
        ]
      },
      "syncStageStartedAt": {
        "description": "Sync stage started at",
        "type": "string",
        "format": "date-time"
      },
      "throttleFailureCount": {
        "description": "Throttle Failure Count",
        "type": "integer"
      },
      "throttleRetryAfter": {
        "description": "Throttle Retry After",
        "type": "string",
        "format": "date-time"
      },
      "connectedAccountId": {
        "type": "string",
        "format": "uuid"
      }
    },
    "required": [
      "position",
      "visibility",
      "type",
      "isContactAutoCreationEnabled",
      "contactAutoCreationPolicy",
      "messageFolderImportPolicy",
      "excludeNonProfessionalEmails",
      "excludeGroupEmails",
      "pendingGroupEmailsAction",
      "isSyncEnabled",
      "syncStage",
      "throttleFailureCount",
      "connectedAccountId"
    ]
  }
}