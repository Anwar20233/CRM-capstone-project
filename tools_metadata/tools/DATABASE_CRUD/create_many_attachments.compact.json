{
  "name": "create_many_attachments",
  "description": "Create multiple Attachments records in a single call. Provide an array of records, each containing the required fields. Maximum 20 records per call. Returns the created records.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "records": {
        "description": "Array of records to create. Each record should contain the required fields. Maximum 20 records per call.",
        "minItems": 1,
        "maxItems": 20,
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "description": "Attachment name",
              "type": "string"
            },
            "file": {
              "description": "Attachment file",
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "fileId": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "label": {
                    "type": "string"
                  }
                },
                "required": [
                  "fileId",
                  "label"
                ]
              }
            },
            "fullPath": {
              "description": "Attachment full path",
              "type": "string"
            },
            "fileCategory": {
              "description": "Attachment file category",
              "type": "string",
              "enum": [
                "ARCHIVE",
                "AUDIO",
                "IMAGE",
                "PRESENTATION",
                "SPREADSHEET",
                "TEXT_DOCUMENT",
                "VIDEO",
                "OTHER"
              ]
            },
            "position": {
              "description": "Use \"first\" to insert at the top, \"last\" for the bottom, or a number for explicit ordering. Leave empty to place at the top (recommended).",
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "string",
                  "const": "first"
                },
                {
                  "type": "string",
                  "const": "last"
                }
              ]
            },
            "targetTask": {
              "description": "Attachment target",
              "type": "string"
            },
            "targetNote": {
              "description": "Attachment target",
              "type": "string"
            },
            "targetPerson": {
              "description": "Attachment target",
              "type": "string"
            },
            "targetCompany": {
              "description": "Attachment target",
              "type": "string"
            },
            "targetOpportunity": {
              "description": "Attachment target",
              "type": "string"
            },
            "targetDashboard": {
              "description": "Attachment target",
              "type": "string"
            },
            "targetWorkflow": {
              "description": "Attachment target",
              "type": "string"
            }
          },
          "required": [
            "fileCategory",
            "position"
          ]
        }
      }
    },
    "required": [
      "records"
    ]
  }
}