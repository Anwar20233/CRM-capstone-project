{
  "name": "update_connected_account",
  "description": "Update an existing Connected Account record. Provide the record ID and only the fields you want to change. Unspecified fields will remain unchanged. Returns the updated record with all current data.",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "position": {
        "description": "Use \"first\" to insert at the top, \"last\" for the bottom, or a number for explicit ordering. Leave empty to place at the top (recommended).",
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "string",
            "const": "first"
          },
          {
            "type": "string",
            "const": "last"
          }
        ]
      },
      "handle": {
        "description": "The account handle (email, username, phone number, etc.)",
        "type": "string"
      },
      "provider": {
        "description": "The account provider",
        "type": "string"
      },
      "accessToken": {
        "description": "Messaging provider access token",
        "type": "string"
      },
      "refreshToken": {
        "description": "Messaging provider refresh token",
        "type": "string"
      },
      "lastSyncHistoryId": {
        "description": "Last sync history ID",
        "type": "string"
      },
      "authFailedAt": {
        "description": "Auth failed at",
        "type": "string",
        "format": "date-time",
        "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
      },
      "lastCredentialsRefreshedAt": {
        "description": "Last credentials refreshed at",
        "type": "string",
        "format": "date-time",
        "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
      },
      "handleAliases": {
        "description": "Handle Aliases",
        "type": "string"
      },
      "scopes": {
        "description": "Scopes",
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "connectionParameters": {
        "description": "JSON object containing custom connection parameters",
        "type": "object",
        "propertyNames": {
          "type": "string"
        },
        "additionalProperties": {}
      },
      "accountOwnerId": {
        "type": "string",
        "format": "uuid",
        "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12})$"
      },
      "id": {
        "type": "string",
        "format": "uuid",
        "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
      }
    },
    "required": [
      "id"
    ],
    "additionalProperties": false
  }
}