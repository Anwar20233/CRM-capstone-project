{
  "name": "create_connected_account",
  "description": "Create a new Connected Account record. Provide all required fields and any optional fields you want to set. The system will automatically handle timestamps and IDs. Returns the created record with all its data.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "position": {
        "description": "Use \"first\" to insert at the top, \"last\" for the bottom, or a number for explicit ordering. Leave empty to place at the top (recommended).",
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "string",
            "const": "first"
          },
          {
            "type": "string",
            "const": "last"
          }
        ]
      },
      "handle": {
        "description": "The account handle (email, username, phone number, etc.)",
        "type": "string"
      },
      "provider": {
        "description": "The account provider",
        "type": "string"
      },
      "accessToken": {
        "description": "Messaging provider access token",
        "type": "string"
      },
      "refreshToken": {
        "description": "Messaging provider refresh token",
        "type": "string"
      },
      "lastSyncHistoryId": {
        "description": "Last sync history ID",
        "type": "string"
      },
      "authFailedAt": {
        "description": "Auth failed at",
        "type": "string",
        "format": "date-time"
      },
      "lastCredentialsRefreshedAt": {
        "description": "Last credentials refreshed at",
        "type": "string",
        "format": "date-time"
      },
      "handleAliases": {
        "description": "Handle Aliases",
        "type": "string"
      },
      "scopes": {
        "description": "Scopes",
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "connectionParameters": {
        "description": "JSON object containing custom connection parameters",
        "type": "object",
        "propertyNames": {
          "type": "string"
        },
        "additionalProperties": {}
      },
      "accountOwnerId": {
        "type": "string",
        "format": "uuid"
      }
    },
    "required": [
      "position",
      "provider",
      "accountOwnerId"
    ]
  }
}