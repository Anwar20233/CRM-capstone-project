            "items": {
              "type": "string"
            }
          },
          "like": {
            "type": "string"
          },
          "ilike": {
            "type": "string"
          },
          "startsWith": {
            "type": "string"
          },
          "endsWith": {
            "type": "string"
          },
          "is": {
            "type": "string",
            "enum": [
              "NULL",
              "NOT_NULL"
            ]
          }
        }
      }
    }
  }
}