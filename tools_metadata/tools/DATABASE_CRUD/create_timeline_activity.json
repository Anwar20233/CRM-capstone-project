{
  "name": "create_timeline_activity",
  "description": "Create a new Timeline Activity record. Provide all required fields and any optional fields you want to set. The system will automatically handle timestamps and IDs. Returns the created record with all its data.",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "position": {
        "description": "Use \"first\" to insert at the top, \"last\" for the bottom, or a number for explicit ordering. Leave empty to place at the top (recommended).",
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "string",
            "const": "first"
          },
          {
            "type": "string",
            "const": "last"
          }
        ]
      },
      "happensAt": {
        "description": "Creation date",
        "type": "string",
        "format": "date-time",
        "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
      },
      "name": {
        "description": "Event name",
        "type": "string"
      },
      "properties": {
        "description": "Json value for event details",
        "type": "object",
        "propertyNames": {
          "type": "string"
        },
        "additionalProperties": {}
      },
      "linkedRecordCachedName": {
        "description": "Cached record name",
        "type": "string"
      },
      "linkedRecordId": {
        "description": "Linked Record id",
        "type": "string",
        "format": "uuid",
        "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12})$"
      },
      "linkedObjectMetadataId": {
        "description": "Linked Object Metadata Id",
        "type": "string",
        "format": "uuid",
        "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12})$"
      },
      "targetCompany": {
        "description": "Event target",
        "type": "string"
      },
      "targetDashboard": {
        "description": "Event target",
        "type": "string"
      },
      "targetNote": {
        "description": "Event target",
        "type": "string"
      },
      "targetOpportunity": {
        "description": "Event target",
        "type": "string"
      },
      "targetPerson": {
        "description": "Event target",
        "type": "string"
      },
      "targetTask": {
        "description": "Event target",
        "type": "string"
      },
      "workspaceMemberId": {
        "type": "string",
        "format": "uuid",
        "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12})$"
      },
      "targetWorkflow": {
        "description": "Event target",
        "type": "string"
      },
      "targetWorkflowVersion": {
        "description": "Event target",
        "type": "string"
      },
      "targetWorkflowRun": {
        "description": "Event target",
        "type": "string"
      }
    },
    "required": [
      "position",
      "happensAt"
    ],
    "additionalProperties": false
  }
}