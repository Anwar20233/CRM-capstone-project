{
  "name": "update_many_workspace_members",
  "description": "Update multiple Workspace Members records matching a filter in a single operation. All matching records will receive the same field values. WARNING: Use specific filters to avoid unintended mass updates. Always verify the filter scope with a find query first. Returns the updated records.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "filter": {
        "description": "Filter to select which records to update. Supports field-level filters and logical operators (or, and, not). WARNING: A broad filter may update many records at once. Always verify the filter scope with a find query first.",
        "$ref": "#/$defs/__schema0"
      },
      "data": {
        "description": "The field values to apply to all matching records. Only include fields you want to change.",
        "type": "object",
        "properties": {
          "position": {
            "description": "Use \"first\" to insert at the top, \"last\" for the bottom, or a number for explicit ordering. Leave empty to place at the top (recommended).",
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "string",
                "const": "first"
              },
              {
                "type": "string",
                "const": "last"
              }
            ]
          },
          "name": {
            "description": "Workspace member name",
            "type": "object",
            "properties": {
              "firstName": {
                "type": "string"
              },
              "lastName": {
                "type": "string"
              }
            }
          },
          "colorScheme": {
            "description": "Preferred color scheme",
            "type": "string"
          },
          "locale": {
            "description": "Preferred language",
            "type": "string"
          },
          "avatarUrl": {
            "description": "Workspace member avatar",
            "type": "string"
          },
          "userEmail": {
            "description": "Related user email address",
            "type": "string"
          },
          "calendarStartDay": {
            "description": "User's preferred start day of the week",
            "type": "integer"
          },
          "userId": {
            "description": "Associated User Id",
            "type": "string",
            "format": "uuid"
          },
          "timeZone": {
            "description": "User time zone",
            "type": "string"
          },
          "dateFormat": {
            "description": "User's preferred date format",
            "type": "string",
            "enum": [
              "SYSTEM",
              "MONTH_FIRST",
              "DAY_FIRST",
              "YEAR_FIRST"
            ]
          },
          "timeFormat": {
            "description": "User's preferred time format",
            "type": "string",
            "enum": [
              "SYSTEM",
              "HOUR_24",
              "HOUR_12"
            ]
          },
          "numberFormat": {
            "description": "User's preferred number format",
            "type": "string",
            "enum": [
              "SYSTEM",
              "COMMAS_AND_DOT",
              "SPACES_AND_COMMA",
              "DOTS_AND_COMMA",
              "APOSTROPHE_AND_DOT"
            ]
          }
        }
      }
    },
    "required": [
      "filter",
      "data"
    ],
    "$defs": {
      "__schema0": {
        "type": "object",
        "properties": {
          "name": {
            "type": "object",
            "properties": {
              "firstName": {
                "description": "Filter by first name",
                "$ref": "#/$defs/_f4"
              },
              "lastName": {
                "description": "Filter by last name",
                "$ref": "#/$defs/_f4"
              }
            }
          },
          "or": {
            "description": "OR condition - matches if ANY of the filters match",
            "type": "array",
            "items": {
              "$ref": "#/$defs/__schema0"
            }
          },
          "and": {
            "description": "AND condition - matches if ALL filters match",
            "type": "array",
            "items": {
              "$ref": "#/$defs/__schema0"
            }
          },
          "not": {
            "description": "NOT condition - matches if the filter does NOT match",
            "$ref": "#/$defs/__schema0"
          }
        }
      },
      "_f4": {
        "type": "object",
        "properties": {
          "eq": {
            "type": "string"
          },
          "neq": {
            "type": "string"
          },
          "like": {
            "type": "string"
          },
          "ilike": {
            "type": "string"
          },
          "startsWith": {
            "type": "string"
          },
          "endsWith": {
            "type": "string"
          },
          "is": {
            "type": "string",
            "enum": [
              "NULL",
              "NOT_NULL"
            ]
          }
        }
      }
    }
  }
}