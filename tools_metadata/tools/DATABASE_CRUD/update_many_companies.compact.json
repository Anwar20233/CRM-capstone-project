      },
      "data": {
        "description": "The field values to apply to all matching records. Only include fields you want to change.",
        "type": "object",
        "properties": {
          "name": {
            "description": "The company name",
            "type": "string"
          },
          "domainName": {
            "description": "The company website URL. We use this url to fetch the company icon",
