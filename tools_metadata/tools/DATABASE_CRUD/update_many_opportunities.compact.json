{
  "name": "update_many_opportunities",
  "description": "Update multiple Opportunities records matching a filter in a single operation. All matching records will receive the same field values. WARNING: Use specific filters to avoid unintended mass updates. Always verify the filter scope with a find query first. Returns the updated records.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "filter": {
        "description": "Filter to select which records to update. Supports field-level filters and logical operators (or, and, not). WARNING: A broad filter may update many records at once. Always verify the filter scope with a find query first.",
        "$ref": "#/$defs/__schema0"
      },
      "data": {
        "description": "The field values to apply to all matching records. Only include fields you want to change.",
        "type": "object",
        "properties": {
          "name": {
            "description": "The opportunity name",
            "type": "string"
          },
          "amount": {
            "description": "Opportunity amount",
            "type": "object",
            "properties": {
              "amountMicros": {
                "type": "number"
              },
              "currencyCode": {
                "type": "string"
              }
            }
          },
          "closeDate": {
            "description": "Opportunity close date",
            "type": "string",
            "format": "date-time"
          },
          "stage": {
            "description": "Opportunity stage",
            "type": "string",
            "enum": [
              "NEW",
              "SCREENING",
              "MEETING",
              "PROPOSAL",
              "CUSTOMER"
            ]
          },
          "position": {
            "description": "Use \"first\" to insert at the top, \"last\" for the bottom, or a number for explicit ordering. Leave empty to place at the top (recommended).",
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "string",
                "const": "first"
              },
              {
                "type": "string",
                "const": "last"
              }
            ]
          },
          "companyId": {
            "type": "string",
            "format": "uuid"
          },
          "pointOfContactId": {
            "type": "string",
            "format": "uuid"
          },
          "ownerId": {
            "type": "string",
            "format": "uuid"
          }
        }
      }
    },
    "required": [
      "filter",
      "data"
    ],
