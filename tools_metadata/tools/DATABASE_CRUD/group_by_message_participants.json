      "groupBy": {
        "description": "Fields to group by (max 2). Each entry must be an object with exactly one field key. Examples: {\"status\": true}, {\"companyId\": true}, {\"createdAt\": {\"granularity\": \"MONTH\", \"timeZone\": \"UTC\"}}. Available: createdAt (date), updatedAt (date), role, handle, displayName, messageId, personId, workspaceMemberId.",
        "minItems": 1,
        "maxItems": 2,
        "type": "array",
        "items": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "createdAt": {
                  "description": "Date field grouping configuration",
                  "type": "object",
                  "properties": {
                    "granularity": {
                      "description": "Date grouping granularity. Default: MONTH.",
                      "default": "MONTH",
                      "type": "string",
                      "enum": [
                        "DAY",
                        "MONTH",
                        "QUARTER",
                        "YEAR",
                        "WEEK",
                        "DAY_OF_THE_WEEK",
                        "MONTH_OF_THE_YEAR",
                        "QUARTER_OF_THE_YEAR"
                      ]
                    },
                    "weekStartDay": {
                      "description": "First day of week (MONDAY, SUNDAY, SATURDAY). Only used when granularity is WEEK.",
                      "type": "string",
                      "enum": [
                        "MONDAY",
                        "SUNDAY",
                        "SATURDAY"
                      ]
                    },
                    "timeZone": {
                      "description": "IANA timezone for date groupings (e.g. \"America/New_York\"). Default: UTC.",
                      "default": "UTC",
                      "type": "string"
                    }
                  },
                  "required": [
                    "granularity",
                    "timeZone"
                  ],
                  "additionalProperties": false
                }
              },
              "required": [
                "createdAt"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "updatedAt": {
                  "description": "Date field grouping configuration",
                  "type": "object",
                  "properties": {
                    "granularity": {
                      "description": "Date grouping granularity. Default: MONTH.",
