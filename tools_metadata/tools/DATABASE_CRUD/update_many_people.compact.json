              },
              "primaryPhoneCallingCode": {
                "type": "string"
              },
              "additionalPhones": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "city": {
            "description": "Contact's city",
            "type": "string"
          },
          "avatarUrl": {
            "description": "Contact's avatar",
            "type": "string"
          },
          "avatarFile": {
            "description": "Contact's avatar file",
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
