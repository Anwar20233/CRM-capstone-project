{
  "name": "create_many_connected_accounts",
  "description": "Create multiple Connected Accounts records in a single call. Provide an array of records, each containing the required fields. Maximum 20 records per call. Returns the created records.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "records": {
        "description": "Array of records to create. Each record should contain the required fields. Maximum 20 records per call.",
        "minItems": 1,
        "maxItems": 20,
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "position": {
              "description": "Use \"first\" to insert at the top, \"last\" for the bottom, or a number for explicit ordering. Leave empty to place at the top (recommended).",
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "string",
                  "const": "first"
                },
                {
                  "type": "string",
                  "const": "last"
                }
              ]
            },
            "handle": {
              "description": "The account handle (email, username, phone number, etc.)",
              "type": "string"
            },
            "provider": {
              "description": "The account provider",
              "type": "string"
            },
            "accessToken": {
              "description": "Messaging provider access token",
              "type": "string"
            },
            "refreshToken": {
              "description": "Messaging provider refresh token",
              "type": "string"
            },
            "lastSyncHistoryId": {
              "description": "Last sync history ID",
              "type": "string"
            },
            "authFailedAt": {
              "description": "Auth failed at",
              "type": "string",
              "format": "date-time"
            },
            "lastCredentialsRefreshedAt": {
              "description": "Last credentials refreshed at",
              "type": "string",
              "format": "date-time"
            },
            "handleAliases": {
              "description": "Handle Aliases",
              "type": "string"
            },
            "scopes": {
              "description": "Scopes",
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "connectionParameters": {
              "description": "JSON object containing custom connection parameters",
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {}
            },
            "accountOwnerId": {
              "type": "string",
              "format": "uuid"
            }
          },
          "required": [
            "position",
            "provider",
            "accountOwnerId"
          ]
        }
      }
    },
    "required": [
      "records"
    ]
  }
}