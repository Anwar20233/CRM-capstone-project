{
  "name": "create_many_companies",
  "description": "Create multiple Companies records in a single call. Provide an array of records, each containing the required fields. Maximum 20 records per call. Returns the created records.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "records": {
        "description": "Array of records to create. Each record should contain the required fields. Maximum 20 records per call.",
        "minItems": 1,
        "maxItems": 20,
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "description": "The company name",
              "type": "string"
            },
            "domainName": {
              "description": "The company website URL. We use this url to fetch the company icon",
              "$ref": "#/$defs/_f3"
            },
            "address": {
              "description": "Address of the company",
              "type": "object",
              "properties": {
                "addressStreet1": {
                  "type": "string"
                },
                "addressStreet2": {
                  "type": "string"
                },
                "addressCity": {
                  "type": "string"
                },
                "addressPostcode": {
                  "type": "string"
                },
                "addressState": {
                  "type": "string"
                },
                "addressCountry": {
                  "type": "string"
                },
                "addressLat": {
                  "type": "number"
                },
                "addressLng": {
                  "type": "number"
                }
              }
            },
            "employees": {
              "description": "Number of employees in the company",
              "type": "integer"
            },
            "linkedinLink": {
              "description": "The company Linkedin account",
              "$ref": "#/$defs/_f3"
            },
            "xLink": {
              "description": "The company Twitter/X account",
              "$ref": "#/$defs/_f3"
            },
            "annualRecurringRevenue": {
              "description": "Annual Recurring Revenue: The actual or estimated annual revenue of the company",
              "type": "object",
              "properties": {
                "amountMicros": {
                  "type": "number"
                },
                "currencyCode": {
                  "type": "string"
                }
              }
            },
            "idealCustomerProfile": {
              "description": "Ideal Customer Profile: Indicates whether the company is the most suitable and valuable customer for you",
              "type": "boolean"
            },
            "position": {
              "description": "Use \"first\" to insert at the top, \"last\" for the bottom, or a number for explicit ordering. Leave empty to place at the top (recommended).",
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "string",
                  "const": "first"
                },
                {
                  "type": "string",
                  "const": "last"
                }
              ]
            },
            "accountOwnerId": {
              "type": "string",
              "format": "uuid"
            }
          },
          "required": [
            "idealCustomerProfile",
            "position"
          ]
        }
      }
    },
    "required": [
      "records"
    ],
    "$defs": {
      "_f3": {
        "type": "object",
        "properties": {
          "primaryLinkLabel": {
            "type": "string"
          },
          "primaryLinkUrl": {
            "type": "string",
            "format": "uri"
          },
          "secondaryLinks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "url": {
                  "type": "string",
                  "format": "uri"
                },
                "label": {
                  "type": "string"
                }
              },
              "required": [
                "url",
                "label"
              ]
            }
          }
        }
      }
    }
  }
}