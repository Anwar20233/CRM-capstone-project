{
  "name": "update_opportunity",
  "description": "Update an existing Opportunity record. Provide the record ID and only the fields you want to change. Unspecified fields will remain unchanged. Returns the updated record with all current data.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "name": {
        "description": "The opportunity name",
        "type": "string"
      },
      "amount": {
        "description": "Opportunity amount",
        "type": "object",
        "properties": {
          "amountMicros": {
            "type": "number"
          },
          "currencyCode": {
            "type": "string"
          }
        }
      },
      "closeDate": {
        "description": "Opportunity close date",
        "type": "string",
        "format": "date-time"
      },
      "stage": {
        "description": "Opportunity stage",
        "type": "string",
        "enum": [
          "NEW",
          "SCREENING",
          "MEETING",
          "PROPOSAL",
          "CUSTOMER"
        ]
      },
      "position": {
        "description": "Use \"first\" to insert at the top, \"last\" for the bottom, or a number for explicit ordering. Leave empty to place at the top (recommended).",
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "string",
            "const": "first"
          },
          {
            "type": "string",
            "const": "last"
          }
        ]
      },
      "companyId": {
        "type": "string",
        "format": "uuid"
      },
      "pointOfContactId": {
        "type": "string",
        "format": "uuid"
      },
      "ownerId": {
        "type": "string",
        "format": "uuid"
      },
      "id": {
        "type": "string",
        "format": "uuid"
      }
    },
    "required": [
      "id"
    ]
  }
}