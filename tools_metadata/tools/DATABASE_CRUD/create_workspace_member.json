{
  "name": "create_workspace_member",
  "description": "Create a new Workspace Member record. Provide all required fields and any optional fields you want to set. The system will automatically handle timestamps and IDs. Returns the created record with all its data.",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "position": {
        "description": "Use \"first\" to insert at the top, \"last\" for the bottom, or a number for explicit ordering. Leave empty to place at the top (recommended).",
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "string",
            "const": "first"
          },
          {
            "type": "string",
            "const": "last"
          }
        ]
      },
      "name": {
        "description": "Workspace member name",
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "colorScheme": {
        "description": "Preferred color scheme",
        "type": "string"
      },
      "locale": {
        "description": "Preferred language",
        "type": "string"
      },
      "avatarUrl": {
        "description": "Workspace member avatar",
        "type": "string"
      },
      "userEmail": {
        "description": "Related user email address",
        "type": "string"
      },
      "calendarStartDay": {
        "description": "User's preferred start day of the week",
        "type": "integer",
        "minimum": -9007199254740991,
        "maximum": 9007199254740991
      },
      "userId": {
        "description": "Associated User Id",
        "type": "string",
        "format": "uuid",
        "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12})$"
      },
      "timeZone": {
        "description": "User time zone",
        "type": "string"
      },
      "dateFormat": {
        "description": "User's preferred date format",
        "type": "string",
        "enum": [
          "SYSTEM",
          "MONTH_FIRST",
          "DAY_FIRST",
          "YEAR_FIRST"
        ]
      },
      "timeFormat": {
        "description": "User's preferred time format",
        "type": "string",
        "enum": [
          "SYSTEM",
          "HOUR_24",
          "HOUR_12"
        ]
      },
      "numberFormat": {
        "description": "User's preferred number format",
        "type": "string",
        "enum": [
          "SYSTEM",
          "COMMAS_AND_DOT",
          "SPACES_AND_COMMA",
          "DOTS_AND_COMMA",
          "APOSTROPHE_AND_DOT"
        ]
      }
    },
    "required": [
      "position",
      "name",
      "colorScheme",
      "locale",
      "calendarStartDay",
      "userId",
      "timeZone",
      "dateFormat",
      "timeFormat",
      "numberFormat"
    ],
    "additionalProperties": false
  }
}