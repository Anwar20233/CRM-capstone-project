{
  "name": "group_by_blocklists",
  "description": "Group Blocklists records by one or two fields and compute an aggregate (COUNT, SUM, AVG, MIN, MAX, etc.). Use for questions like \"how many deals per stage?\" or \"total revenue by company\". Returns groups with dimension values and aggregate results, ordered by the aggregate value.",
  "inputSchema": {
    "type": "object",
    "required": [
      "groupBy",
      "aggregateOperation",
      "limit",
      "orderBy"
    ],
    "$defs": {
      "__schema0": {
        "type": "object",
        "properties": {
          "handle": {
            "type": "object",
            "properties": {
              "eq": {
                "type": "string"
              },
              "neq": {
                "type": "string"
              },
              "in": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "like": {
                "type": "string"
              },
              "ilike": {
                "type": "string"
              },
              "startsWith": {
                "type": "string"
              },
              "endsWith": {
                "type": "string"
              },
              "is": {
                "type": "string",
                "enum": [
                  "NULL",
                  "NOT_NULL"
                ]
              }
            }
          },
          "workspaceMemberId": {
            "type": "object",
            "properties": {
              "eq": {
                "type": "string",
                "format": "uuid"
              },
              "neq": {
                "type": "string",
                "format": "uuid"
              },
              "in": {
                "type": "array",
                "items": {
                  "type": "string",
                  "format": "uuid"
                }
              },
              "is": {
                "type": "string",
                "enum": [
                  "NULL",
                  "NOT_NULL"
                ]
              }
            }
          },
          "or": {
            "description": "OR condition - matches if ANY of the filters match",
            "type": "array",
            "items": {
              "$ref": "#/$defs/__schema0"
            }
          },
          "and": {
            "description": "AND condition - matches if ALL filters match",
            "type": "array",
            "items": {
              "$ref": "#/$defs/__schema0"
            }
          },
          "not": {
            "description": "NOT condition - matches if the filter does NOT match",
            "$ref": "#/$defs/__schema0"
          }
        }
      },
      "_f7": {
        "type": "object",
        "properties": {
          "granularity": {
            "description": "Date grouping granularity. Default: MONTH.",
            "default": "MONTH",
            "type": "string",
            "enum": [
              "DAY",
              "MONTH",
              "QUARTER",
              "YEAR",
              "WEEK",
              "DAY_OF_THE_WEEK",
              "MONTH_OF_THE_YEAR",
              "QUARTER_OF_THE_YEAR"
            ]
          },
          "weekStartDay": {
            "description": "First day of week (MONDAY, SUNDAY, SATURDAY). Only used when granularity is WEEK.",
            "type": "string",
            "enum": [
              "MONDAY",
              "SUNDAY",
              "SATURDAY"
            ]
          },
          "timeZone": {
            "description": "IANA timezone for date groupings (e.g. \"America/New_York\"). Default: UTC.",
            "default": "UTC",
            "type": "string"
          }
        },
        "required": [
          "granularity",
          "timeZone"
        ]
      }
    },
    "properties": {
      "groupBy": {
        "description": "Fields to group by (max 2). Each entry must be an object with exactly one field key. Examples: {\"status\": true}, {\"companyId\": true}, {\"createdAt\": {\"granularity\": \"MONTH\", \"timeZone\": \"UTC\"}}. Available: createdAt (date), updatedAt (date), handle, workspaceMemberId.",
        "minItems": 1,
        "maxItems": 2,
        "type": "array",
        "items": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "createdAt": {
                  "description": "Date field grouping configuration",
                  "$ref": "#/$defs/_f7"
                }
              },
              "required": [
                "createdAt"
              ]
            },
            {
              "type": "object",
              "properties": {
                "updatedAt": {
                  "description": "Date field grouping configuration",
                  "$ref": "#/$defs/_f7"
                }
              },
              "required": [
                "updatedAt"
              ]
            },
            {
              "type": "object",
              "properties": {
                "handle": {
                  "type": "boolean",
                  "const": true
                }
              },
              "required": [
                "handle"
              ]
            },
            {
              "type": "object",
              "properties": {
                "workspaceMemberId": {
                  "type": "boolean",
                  "const": true
                }
              },
              "required": [
                "workspaceMemberId"
              ]
            }
          ]
        }
      },
      "aggregateOperation": {
        "description": "Aggregate operation to apply per group. Default: COUNT. Any operation other than COUNT requires aggregateFieldName.",
        "default": "COUNT",
        "type": "string",
        "enum": [
          "MIN",
          "MAX",
          "AVG",
          "SUM",
          "COUNT",
          "COUNT_UNIQUE_VALUES",
          "COUNT_EMPTY",
          "COUNT_NOT_EMPTY",
          "COUNT_TRUE",
          "COUNT_FALSE",
          "PERCENTAGE_EMPTY",
          "PERCENTAGE_NOT_EMPTY"
        ]
      },
      "aggregateFieldName": {
        "description": "Field to aggregate. Required for any operation other than COUNT. Available fields: id, createdAt, updatedAt, deletedAt, createdBy, updatedBy, position, searchVector, handle.",
        "type": "string"
      },
      "limit": {
        "default": 50,
        "type": "integer",
        "maximum": 100
      },
      "orderBy": {
        "default": "DESC",
        "type": "string",
        "enum": [
          "ASC",
          "DESC"
        ]
      }
    },
    "allOf": [
      {
        "$ref": "#/$defs/__schema0"
      }
    ]
  }
}