{
  "name": "create_many_calendar_event_participants",
  "description": "Create multiple Calendar event participants records in a single call. Provide an array of records, each containing the required fields. Maximum 20 records per call. Returns the created records.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "records": {
        "description": "Array of records to create. Each record should contain the required fields. Maximum 20 records per call.",
        "minItems": 1,
        "maxItems": 20,
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "position": {
              "description": "Use \"first\" to insert at the top, \"last\" for the bottom, or a number for explicit ordering. Leave empty to place at the top (recommended).",
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "string",
                  "const": "first"
                },
                {
                  "type": "string",
                  "const": "last"
                }
              ]
            },
            "handle": {
              "description": "Handle",
              "type": "string"
            },
            "displayName": {
              "description": "Display Name",
              "type": "string"
            },
            "isOrganizer": {
              "description": "Is Organizer",
              "type": "boolean"
            },
            "responseStatus": {
              "description": "Response Status",
              "type": "string",
              "enum": [
                "NEEDS_ACTION",
                "DECLINED",
                "TENTATIVE",
                "ACCEPTED"
              ]
            },
            "calendarEventId": {
              "type": "string",
              "format": "uuid"
            },
            "personId": {
              "type": "string",
              "format": "uuid"
            },
            "workspaceMemberId": {
              "type": "string",
              "format": "uuid"
            }
          },
          "required": [
            "position",
            "isOrganizer",
            "responseStatus",
            "calendarEventId"
          ]
        }
      }
    },
    "required": [
      "records"
    ]
  }
}