{
  "name": "group_by_people",
  "description": "Group People records by one or two fields and compute an aggregate (COUNT, SUM, AVG, MIN, MAX, etc.). Use for questions like \"how many deals per stage?\" or \"total revenue by company\". Returns groups with dimension values and aggregate results, ordered by the aggregate value.",
  "inputSchema": {
    "type": "object",
    "required": [
      "groupBy",
      "aggregateOperation",
      "limit",
      "orderBy"
    ],
    "$defs": {
      "__schema0": {
        "type": "object",
        "properties": {
          "name": {
            "type": "object",
            "properties": {
              "firstName": {
                "description": "Filter by first name",
                "$ref": "#/$defs/_f3"
              },
              "lastName": {
                "description": "Filter by last name",
                "$ref": "#/$defs/_f3"
              }
            }
          },
          "emails": {
            "type": "object",
            "properties": {
              "primaryEmail": {
                "description": "Filter by primary email",
                "type": "object",
                "properties": {
                  "eq": {
                    "type": "string",
                    "format": "email"
                  },
                  "neq": {
                    "type": "string",
                    "format": "email"
                  },
                  "like": {
                    "type": "string"
                  },
                  "ilike": {
                    "type": "string"
                  },
                  "is": {
                    "type": "string",
                    "enum": [
                      "NULL",
                      "NOT_NULL"
                    ]
                  }
                }
              }
            }
          },
          "linkedinLink": {
            "$ref": "#/$defs/_f6"
          },
          "xLink": {
            "$ref": "#/$defs/_f6"
          },
          "jobTitle": {
            "$ref": "#/$defs/_f8"
          },
          "phones": {
            "type": "object",
            "properties": {
              "primaryPhoneNumber": {
                "description": "Filter by primary phone number",
                "type": "object",
                "properties": {
                  "eq": {
                    "type": "string"
                  },
                  "neq": {
                    "type": "string"
                  },
                  "like": {
                    "type": "string"
                  },
                  "ilike": {
                    "type": "string"
                  },
                  "is": {
                    "type": "string",
                    "enum": [
                      "NULL",
                      "NOT_NULL"
                    ]
                  }
                }
              }
            }
          },
          "city": {
            "$ref": "#/$defs/_f8"
          },
          "companyId": {
            "type": "object",
            "properties": {
              "eq": {
                "type": "string",
                "format": "uuid"
              },
              "neq": {
                "type": "string",
                "format": "uuid"
              },
              "in": {
                "type": "array",
                "items": {
                  "type": "string",
                  "format": "uuid"
                }
              },
              "is": {
                "type": "string",
                "enum": [
                  "NULL",
                  "NOT_NULL"
                ]
              }
            }
          },
          "or": {
            "description": "OR condition - matches if ANY of the filters match",
            "type": "array",
            "items": {
              "$ref": "#/$defs/__schema0"
            }
          },
          "and": {
            "description": "AND condition - matches if ALL filters match",
            "type": "array",
            "items": {
              "$ref": "#/$defs/__schema0"
            }
          },
          "not": {
            "description": "NOT condition - matches if the filter does NOT match",
            "$ref": "#/$defs/__schema0"
          }
        }
      },
      "_f3": {
        "type": "object",
        "properties": {
          "eq": {
            "type": "string"
          },
          "neq": {
            "type": "string"
          },
          "like": {
            "type": "string"
          },
          "ilike": {
            "type": "string"
          },
          "startsWith": {
            "type": "string"
          },
          "endsWith": {
            "type": "string"
          },
          "is": {
            "type": "string",
            "enum": [
              "NULL",
              "NOT_NULL"
            ]
          }
        }
      },
      "_f6": {
        "type": "object",
        "properties": {
          "primaryLinkUrl": {
            "description": "Filter by primary link URL",
            "$ref": "#/$defs/_f7"
          }
        }
      },
      "_f7": {
        "type": "object",
        "properties": {
          "eq": {
            "type": "string",
            "format": "uri"
          },
          "neq": {
            "type": "string",
            "format": "uri"
          },
          "like": {
            "type": "string"
          },
          "ilike": {
            "type": "string"
          },
          "is": {
            "type": "string",
            "enum": [
              "NULL",
              "NOT_NULL"
            ]
          }
        }
      },
      "_f8": {
        "type": "object",
        "properties": {
          "eq": {
            "type": "string"
          },
          "neq": {
            "type": "string"
          },
          "in": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "like": {
            "type": "string"
          },
          "ilike": {
            "type": "string"
          },
          "startsWith": {
            "type": "string"
          },
          "endsWith": {
            "type": "string"
          },
          "is": {
            "type": "string",
            "enum": [
              "NULL",
              "NOT_NULL"
            ]
          }
        }
      },
      "_f14": {
        "type": "object",
        "properties": {
          "granularity": {
            "description": "Date grouping granularity. Default: MONTH.",
            "default": "MONTH",
            "type": "string",
            "enum": [
              "DAY",
              "MONTH",
              "QUARTER",
              "YEAR",
              "WEEK",
              "DAY_OF_THE_WEEK",
              "MONTH_OF_THE_YEAR",
              "QUARTER_OF_THE_YEAR"
            ]
          },
          "weekStartDay": {
            "description": "First day of week (MONDAY, SUNDAY, SATURDAY). Only used when granularity is WEEK.",
            "type": "string",
            "enum": [
              "MONDAY",
              "SUNDAY",
              "SATURDAY"
            ]
          },
          "timeZone": {
            "description": "IANA timezone for date groupings (e.g. \"America/New_York\"). Default: UTC.",
            "default": "UTC",
            "type": "string"
          }
        },
        "required": [
          "granularity",
          "timeZone"
        ]
      }
    },
    "properties": {
      "groupBy": {
        "description": "Fields to group by (max 2). Each entry must be an object with exactly one field key. Examples: {\"status\": true}, {\"companyId\": true}, {\"createdAt\": {\"granularity\": \"MONTH\", \"timeZone\": \"UTC\"}}. Available: createdAt (date), updatedAt (date), name.firstName, name.lastName, emails.primaryEmail, linkedinLink.primaryLinkLabel, linkedinLink.primaryLinkUrl, xLink.primaryLinkLabel, xLink.primaryLinkUrl, jobTitle, phones.primaryPhoneNumber, phones.primaryPhoneCountryCode, phones.primaryPhoneCallingCode, city, companyId.",
        "minItems": 1,
        "maxItems": 2,
        "type": "array",
        "items": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "createdAt": {
                  "description": "Date field grouping configuration",
                  "$ref": "#/$defs/_f14"
                }
              },
              "required": [
                "createdAt"
              ]
            },
            {
              "type": "object",
              "properties": {
                "updatedAt": {
                  "description": "Date field grouping configuration",
                  "$ref": "#/$defs/_f14"
                }
              },
              "required": [
                "updatedAt"
              ]
            },
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "object",
                  "properties": {
                    "firstName": {
                      "type": "boolean",
                      "const": true
                    }
                  },
                  "required": [
                    "firstName"
                  ]
                }
              },
              "required": [
                "name"
              ]
            },
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "object",
                  "properties": {
                    "lastName": {
                      "type": "boolean",
                      "const": true
                    }
                  },
                  "required": [
                    "lastName"
                  ]
                }
              },
              "required": [
                "name"
              ]
            },
            {
              "type": "object",
              "properties": {
                "emails": {
                  "type": "object",
                  "properties": {
                    "primaryEmail": {
                      "type": "boolean",
                      "const": true
                    }
                  },
                  "required": [
                    "primaryEmail"
                  ]
                }
              },
              "required": [
                "emails"
              ]
            },
            {
              "type": "object",
              "properties": {
                "linkedinLink": {
                  "type": "object",
                  "properties": {
                    "primaryLinkLabel": {
                      "type": "boolean",
                      "const": true
                    }
                  },
                  "required": [
                    "primaryLinkLabel"
                  ]
                }
              },
              "required": [
                "linkedinLink"
              ]
            },
            {
              "type": "object",
              "properties": {
                "linkedinLink": {
                  "type": "object",
                  "properties": {
                    "primaryLinkUrl": {
                      "type": "boolean",
                      "const": true
                    }
                  },
                  "required": [
                    "primaryLinkUrl"
                  ]
                }
              },
              "required": [
                "linkedinLink"
              ]
            },
            {
              "type": "object",
              "properties": {
                "xLink": {
                  "type": "object",
                  "properties": {
                    "primaryLinkLabel": {
                      "type": "boolean",
                      "const": true
                    }
                  },
                  "required": [
                    "primaryLinkLabel"
                  ]
                }
              },
              "required": [
                "xLink"
              ]
            },
            {
              "type": "object",
              "properties": {
                "xLink": {
                  "type": "object",
                  "properties": {
                    "primaryLinkUrl": {
                      "type": "boolean",
                      "const": true
                    }
                  },
                  "required": [
                    "primaryLinkUrl"
                  ]
                }
              },
              "required": [
                "xLink"
              ]
            },
            {
              "type": "object",
              "properties": {
                "jobTitle": {
                  "type": "boolean",
                  "const": true
                }
              },
              "required": [
                "jobTitle"
              ]
            },
            {
              "type": "object",
              "properties": {
                "phones": {
                  "type": "object",
                  "properties": {
                    "primaryPhoneNumber": {
                      "type": "boolean",
                      "const": true
                    }
                  },
                  "required": [
                    "primaryPhoneNumber"
                  ]
                }
              },
              "required": [
                "phones"
              ]
            },
            {
              "type": "object",
              "properties": {
                "phones": {
                  "type": "object",
                  "properties": {
                    "primaryPhoneCountryCode": {
                      "type": "boolean",
                      "const": true
                    }
                  },
                  "required": [
                    "primaryPhoneCountryCode"
                  ]
                }
              },
              "required": [
                "phones"
              ]
            },
            {
              "type": "object",
              "properties": {
                "phones": {
                  "type": "object",
                  "properties": {
                    "primaryPhoneCallingCode": {
                      "type": "boolean",
                      "const": true
                    }
                  },
                  "required": [
                    "primaryPhoneCallingCode"
                  ]
                }
              },
              "required": [
                "phones"
              ]
            },
            {
              "type": "object",
              "properties": {
                "city": {
                  "type": "boolean",
                  "const": true
                }
              },
              "required": [
                "city"
              ]
            },
            {
              "type": "object",
              "properties": {
                "companyId": {
                  "type": "boolean",
                  "const": true
                }
              },
              "required": [
                "companyId"
              ]
            }
          ]
        }
      },
      "aggregateOperation": {
        "description": "Aggregate operation to apply per group. Default: COUNT. Any operation other than COUNT requires aggregateFieldName.",
        "default": "COUNT",
        "type": "string",
        "enum": [
          "MIN",
          "MAX",
          "AVG",
          "SUM",
          "COUNT",
          "COUNT_UNIQUE_VALUES",
          "COUNT_EMPTY",
          "COUNT_NOT_EMPTY",
          "COUNT_TRUE",
          "COUNT_FALSE",
          "PERCENTAGE_EMPTY",
          "PERCENTAGE_NOT_EMPTY"
        ]
      },
      "aggregateFieldName": {
        "description": "Field to aggregate. Required for any operation other than COUNT. Available fields: id, createdAt, updatedAt, deletedAt, name, emails, linkedinLink, xLink, jobTitle, phones, city, avatarUrl, avatarFile, position, createdBy, updatedBy, searchVector.",
        "type": "string"
      },
      "limit": {
        "default": 50,
        "type": "integer",
        "maximum": 100
      },
      "orderBy": {
        "default": "DESC",
        "type": "string",
        "enum": [
          "ASC",
          "DESC"
        ]
      }
    },
    "allOf": [
      {
        "$ref": "#/$defs/__schema0"
      }
    ]
  }
}