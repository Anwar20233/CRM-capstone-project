      },
      "data": {
        "description": "The field values to apply to all matching records. Only include fields you want to change.",
        "type": "object",
        "properties": {
          "position": {
            "description": "Use \"first\" to insert at the top, \"last\" for the bottom, or a number for explicit ordering. Leave empty to place at the top (recommended).",
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "string",
                "const": "first"
              },
              {
                "type": "string",
                "const": "last"
              }
            ]
          },
          "messageExternalId": {
            "description": "Message id from the messaging provider",
            "type": "string"
          },
          "messageThreadExternalId": {
            "description": "Thread id from the messaging provider",
            "type": "string"
          },
          "direction": {
            "description": "Message Direction",
            "type": "string",
            "enum": [
              "INCOMING",
              "OUTGOING"
            ]
          },
          "messageChannelId": {
            "description": "Message Channel Id",
            "type": "string",
            "format": "uuid"
          },
          "messageId": {
            "type": "string",
            "format": "uuid"
          },
          "messageThreadId": {
            "type": "string",
            "format": "uuid"
          }
        }
      }
    },
    "required": [
      "filter",
      "data"
    ],
