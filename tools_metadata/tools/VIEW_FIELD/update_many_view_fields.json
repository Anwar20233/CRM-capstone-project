{
  "name": "update_many_view_fields",
  "description": "Update multiple columns in a view at once. More efficient than calling update_view_field multiple times. Each item must include the view field ID and properties to update. Same constraints as update_view_field apply to each item.",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "viewFields": {
        "description": "Array of view field updates to apply (1-50 items).",
        "minItems": 1,
        "maxItems": 50,
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "description": "The ID of the view field to update. Obtain this from get_view_fields.",
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            },
            "isVisible": {
              "description": "Whether the field is visible.",
              "type": "boolean"
            },
            "size": {
              "description": "Column width in pixels.",
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 9007199254740991
            },
            "position": {
              "description": "Position of the field.",
              "type": "number"
            },
            "aggregateOperation": {
              "description": "Aggregate operation for this field.",
              "type": "string",
              "enum": [
                "MIN",
                "MAX",
                "AVG",
                "SUM",
                "COUNT",
                "COUNT_UNIQUE_VALUES",
                "COUNT_EMPTY",
                "COUNT_NOT_EMPTY",
                "COUNT_TRUE",
                "COUNT_FALSE",
                "PERCENTAGE_EMPTY",
                "PERCENTAGE_NOT_EMPTY"
              ]
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "viewFields"
    ],
    "additionalProperties": false
  }
}